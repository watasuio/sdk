{
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "paths": {
      "@watasu/sdk": ["../ts/dist/index.d.ts"],
      "@watasu/sdk/code-interpreter": ["../ts/dist/codeInterpreter.d.ts"]
    },
    "rootDir": "src",
    "strict": true,
    "target": "ES2022",
    "typeRoots": ["./node_modules/@types", "../ts/node_modules/@types"]
  },
  "include": ["src/**/*.ts"]
}
